  "keyFeatures": [
    "Role-based back-office with admin, veterinarian, and employee dashboards",
    "Animal management with feeding logs, health state reports, and click statistics",
    "Habitat management with veterinarian improvement suggestions",
    "Granular permission system with per-role and per-user permissions",
    "Public-facing pages for animals, habitats, services, and schedules",
    "REST API exposing animals, habitats, services, schedules, and testimonials",
    "Cloudinary integration for responsive image management",
    "Docker and local deployment options with MariaDB/MySQL"
  ],
  "publicApiSurface": [
    "GET /api/animals — List all animals",
    "GET /api/animals/{id} — Get animal by ID",
    "GET /api/habitats — List all habitats",
    "GET /api/habitats/{id} — Get habitat by ID",
    "GET /api/services — List all services",
    "GET /api/schedules — Get zoo schedules",
    "GET /api/testimonials — Get validated testimonials"
  ]
